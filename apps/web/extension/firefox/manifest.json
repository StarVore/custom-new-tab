{
  "manifest_version": 3,
  "name": "NASA APOD Custom New Tab",
  "version": "1.0.0",
  "description": "A customisable new tab page with bookmarks and NASA APOD background.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "nasa-apod-custom-new-tab@starvorelabs",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
