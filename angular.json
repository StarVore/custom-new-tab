{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": false
  },
  "newProjectRoot": "projects",
  "projects": {
    "CustomNewTab": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "apps/web/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "apps/web/src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "apps/web/public"
              }
            ],
            "styles": ["apps/web/src/styles.scss"]
          },
          "configurations": {
            "production": {
              "serviceWorker": "ngsw-config.json",
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            },
            "chrome": {
              "outputHashing": "none",
              "fileReplacements": [
                {
                  "replace": "apps/web/src/app/app.config.ts",
                  "with": "apps/web/src/app/app.config.extension.ts"
                }
              ],
              "assets": [
                {
                  "glob": "**/*",
                  "input": "apps/web/public"
                },
                {
                  "glob": "**/*",
                  "input": "apps/web/extension/chrome/icons",
                  "output": "/icons"
                },
                {
                  "glob": "manifest.json",
                  "input": "apps/web/extension/chrome",
                  "output": "/"
                }
              ]
            },
            "firefox": {
              "outputHashing": "none",
              "fileReplacements": [
                {
                  "replace": "apps/web/src/app/app.config.ts",
                  "with": "apps/web/src/app/app.config.extension.ts"
                }
              ],
              "assets": [
                {
                  "glob": "**/*",
                  "input": "apps/web/public"
                },
                {
                  "glob": "**/*",
                  "input": "apps/web/extension/firefox/icons",
                  "output": "/icons"
                },
                {
                  "glob": "manifest.json",
                  "input": "apps/web/extension/firefox",
                  "output": "/"
                }
              ]
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "CustomNewTab:build:production"
            },
            "development": {
              "buildTarget": "CustomNewTab:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "runner": "vitest",
            "tsConfig": "tsconfig.spec.json"
          },
          "configurations": {
            "coverage": {
              "watch": false,
              "coverage": true,
              "coverageReporters": ["text-summary", "lcov", "html"],
              "coverageExclude": [
                "**/*.html",
                "**/main.ts",
                "**/app.config.ts",
                "**/app.config.extension.ts",
                "**/models/**",
                "**/environments/**"
              ]
            },
            "ci": {
              "watch": false,
              "coverage": true,
              "coverageReporters": ["text-summary", "lcov"],
              "coverageThresholds": {
                "statements": 90,
                "branches": 90,
                "functions": 90,
                "lines": 90
              },
              "coverageExclude": [
                "**/*.html",
                "**/main.ts",
                "**/app.config.ts",
                "**/app.config.extension.ts",
                "**/models/**",
                "**/environments/**"
              ]
            }
          }
        }
      }
    }
  }
}
