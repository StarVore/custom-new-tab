# ── Git build source ──────────────────────────────────────────────────────────
# Compose builds directly from this GitHub repository and ref.
GIT_OWNER_REPO=StarVore/custom-new-tab
GIT_REF=main
POCKETBASE_VERSION=0.36.7

# ── Ports ─────────────────────────────────────────────────────────────────────
# Host ports exposed for each runtime service.
WEB_PORT=80
WEB_TLS_PORT=443
POCKETBASE_PORT=8090
APOD_PROXY_PORT=3001

# ── Process identity ──────────────────────────────────────────────────────────
# UID / GID used for writing to persistent volumes (PocketBase data).
# Run `id` on your host to find the right values.
PUID=1000
PGID=1000

# ── Timezone ───────────────────────────────────────────────────────────────────
TZ=UTC

# ── TLS (optional) ────────────────────────────────────────────────────────────
# Leave ENABLE_TLS=false for HTTP-only operation (default).
# Set to true and provide the host paths to your certificate and private key
# to enable HTTPS on the web service.
#
# Example:
#   ENABLE_TLS=true
#   TLS_CERT_PATH=/etc/ssl/my-domain/cert.pem
#   TLS_KEY_PATH=/etc/ssl/my-domain/key.pem
ENABLE_TLS=false
TLS_CERT_PATH=./certs/cert.pem
TLS_KEY_PATH=./certs/key.pem
