# ── Git build source ──────────────────────────────────────────────────────────
# Compose builds directly from this GitHub repository and ref.
GIT_OWNER_REPO=StarVore/custom-new-tab
GIT_REF=main
POCKETBASE_VERSION=0.36.7

# ── Ports ─────────────────────────────────────────────────────────────────────
# Host ports exposed for each runtime service.
WEB_PORT=80
WEB_TLS_PORT=443
POCKETBASE_PORT=8090
APOD_PROXY_PORT=3001

# ── Process identity ──────────────────────────────────────────────────────────
# UID / GID used for writing to persistent volumes (PocketBase data).
# Run `id` on your host to find the right values.
PUID=1000
PGID=1000

# ── Timezone ───────────────────────────────────────────────────────────────────
TZ=UTC

# ── TLS (optional) ────────────────────────────────────────────────────────────
# Leave ENABLE_TLS=false for HTTP-only operation (default).
# Set to true and provide the host directory that contains cert.pem and key.pem
# to enable HTTPS on the web service.
#
# Example:
#   ENABLE_TLS=true
#   TLS_CERTS_DIR=/path/to/certs
ENABLE_TLS=false
TLS_CERTS_DIR=./certs

# Optional: enable HTTPS for the APOD proxy using the same cert directory.
# When enabled, configure APOD URL as https://<host>:${APOD_PROXY_PORT}.
APOD_ENABLE_TLS=false
